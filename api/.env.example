# Copy to api/.env and fill in real values.

NODE_ENV=development
PORT=5001
CLIENT_URL=http://localhost:3000

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=wpdevmanager
DB_USER=wpdev
DB_PASSWORD=change-me

REDIS_URL=redis://127.0.0.1:6379

JWT_SECRET=change-me-to-a-long-random-string
CREDENTIAL_ENCRYPTION_SECRET=change-me-to-an-independent-long-random-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d
JWT_ISSUER=ahm-web-manager-api
JWT_AUDIENCE=ahm-web-manager-web
REFRESH_COOKIE_NAME=ahm_refresh
REFRESH_COOKIE_SECURE=false
REFRESH_COOKIE_SAME_SITE=lax
# REFRESH_COOKIE_DOMAIN=.example.com
BCRYPT_ROUNDS=12

# Google OAuth email delivery for invites, OTPs, and password resets
GOOGLE_OAUTH_EMAIL=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
INVITE_TOKEN_TTL_HOURS=24
PROFILE_OTP_TTL_MINUTES=10

AUTH_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_RATE_LIMIT_MAX_REQUESTS=20
API_RATE_LIMIT_WINDOW_SECONDS=60
API_RATE_LIMIT_MAX_REQUESTS=120
USER_RATE_LIMIT_WINDOW_SECONDS=60
USER_RATE_LIMIT_MAX_REQUESTS=240

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=no-reply@localhost

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AI_REQUEST_TIMEOUT_MS=60000
AI_MAX_INPUT_CHARS=20000
AI_MAX_FILE_CHARS=12000
CLICKUP_API_TOKEN=
# Public Sheets can use an API key. Private Sheets require both service-account values
# and must be shared with GOOGLE_SERVICE_ACCOUNT_EMAIL as Viewer.
GOOGLE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Keep this on one line and encode line breaks as \n.
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
CLAUDE_API_KEY=
PAGESPEED_API_KEY=
UPTIMEROBOT_API_KEY=

# Website Health and AHM Core.
WEBSITE_HEALTH_MAX_PAGES=25
WEBSITE_HEALTH_PAGE_TIMEOUT_MS=30000
WEBSITE_HEALTH_SCAN_TIMEOUT_MS=1200000
AHM_CORE_PAIRING_TTL_MINUTES=10
PUBLIC_API_URL=http://localhost:5001
# DANGER: SSRF escape hatch for local/staging testing ONLY. Comma-separated
# hostnames/IPs allowed to bypass the private-network guard. Leave EMPTY in production.
WEBSITE_HEALTH_ALLOWED_HOSTS=

REPORT_EMAIL=lead@agency.com

# Viktor AI agent (OAuth2 delegation). Leave secret blank to disable token issuance.
VIKTOR_CLIENT_ID=viktor
VIKTOR_CLIENT_SECRET=
# Comma-separated exact redirect URIs Viktor will receive the auth code at.
VIKTOR_REDIRECT_URIS=
AGENT_ACCESS_TTL=15m
AGENT_REFRESH_TTL=30d
AGENT_AUTH_CODE_TTL_SECONDS=300
AGENT_PROPOSAL_TTL_SECONDS=900
AGENT_TOKEN_AUDIENCE=ahm-agent

# Wall-clock timezone for the notification digest scheduler (daily/pre-shift/weekly).
TIMEZONE=Europe/London
